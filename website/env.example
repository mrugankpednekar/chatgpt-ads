# Copy to .env.local for local development:
#   cp env.example .env.local

# Required for live (non-cached) simulations
OPENAI_API_KEY=

# Optional: force live OpenAI runs even with default Bubble Skincare form
# NEXT_PUBLIC_SKIP_DEMO_CACHE=true

# Optional: always prefer demo cache when form matches DEMO_BRAND
# NEXT_PUBLIC_DEMO_MODE=true
