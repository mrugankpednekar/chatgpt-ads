OPENAI_API_KEY=

# Allowed sign-in emails (comma-separated) and shared password
AUTH_ALLOWED_EMAILS=you@yourcompany.com
AUTH_PASSWORD=
# Optional: separate secret for session signing (falls back to AUTH_PASSWORD)
AUTH_SESSION_SECRET=

# Set to true to force live OpenAI simulation instead of cached demo replay
NEXT_PUBLIC_SKIP_DEMO_CACHE=false

# Book a demo CTA — defaults to Calendly
NEXT_PUBLIC_BOOK_DEMO_URL=https://calendly.com/mrugank-mit/mrugank-contextads
